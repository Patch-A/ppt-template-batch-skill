{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["template"],
  "properties": {
    "template": {"description": "用户上传的 PPTX/PPT 模板", "type": "string"},
    "mode": {"enum": ["generic", "buyer_board", "buyer_briefing"]},
    "country": {"type": "string"},
    "procurement_need": {"type": "string"},
    "buyer_count": {"type": "integer", "minimum": 1, "maximum": 100},
    "records": {"type": ["object", "array"]},
    "allow_page_expand": {"type": "boolean", "default": true},
    "need_images": {"type": "boolean", "default": true},
    "contract_version": {"type": "string", "default": "1.0"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {"type": "string"},
          "url": {"type": "string"},
          "status": {"enum": ["verified", "pending", "unavailable"]}
        },
        "additionalProperties": true
      }
    },
    "verification_status": {"enum": ["verified", "partial", "pending", "failed"]},
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
